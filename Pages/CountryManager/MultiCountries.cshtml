@page
@model TourismApp.Pages.CountryManager.MultiCountriesModel

<h2>Cadastrar vários países</h2>

<form method="post">

    @for (int i = 0; i < Model.Countries.Count; i++)
    {
        <div>

            <label>Nome:</label>
            <input asp-for="Countries[i].CountryName" />

            <label>Código:</label>
            <input asp-for="Countries[i].CountryCode" />

        </div>
        <br>
    }

    <button type="submit">Salvar</button>

</form>